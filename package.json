{
  "name": "exam-platform",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "concurrently --names \"api,ui\" --prefix-colors \"cyan,magenta\" \"node index.js\" \"npm run dev --prefix frontend\"",
    "install:all": "npm install && npm install --prefix frontend",
    "seed": "node prisma/seed.js",
    "db:push": "npx prisma db push --accept-data-loss",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "test:e2e": "npm run test:e2e --prefix frontend"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.18.0",
    "prisma": "5.22.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
