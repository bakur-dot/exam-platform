# ─── Database ────────────────────────────────────────────────────────────────
# Local development (relative path from project root):
DATABASE_URL="file:./prisma/dev.db"
# Docker / production (absolute path inside the container):
# DATABASE_URL="file:/app/prisma/dev.db"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_a_different_64_char_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── TOTP Encryption (AES-256-GCM — 64-char hex = 32 bytes) ─────────────────
TOTP_ENCRYPTION_KEY=replace_with_a_64_char_hex_secret

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Exam Platform"
